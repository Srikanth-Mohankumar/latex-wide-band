%% wideband.sty -- proof of concept
%%
%% Full-width band (e.g. a wide equation) inside a twocolumn page,
%% WITHOUT balancing or flushing the columns first.  Text in both
%% columns continues below the band.
%%
%% Requires LuaLaTeX. One pending band is supported. Requests found in
%% column 1 may be placed on the current page; requests found in column 2
%% are deterministically deferred to the top of the next page. This avoids
%% destructive reconstruction of an already-finalized left column.
%%
%% Usage:
%%   \usepackage{wideband}
%%   ...
%%   \begin{wideband}
%%     \begin{equation} ...wide equation... \end{equation}
%%   \end{wideband}
%%
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{wideband}[2026/07/10 v0.4 production-safe policy A (deterministic right-column deferral)]

\RequirePackage{iftex}
\RequireLuaTeX

%% ------------------------------------------------------------------
%% registers and parameters
%% ------------------------------------------------------------------
\newbox\wb@band     % the decorated band, \textwidth wide
\newbox\wb@body     % captured environment body before decoration
\newbox\wb@discard  % rejected nested/pending request body
\newbox\wb@Ltop     % left column above the band
\newbox\wb@Lbot     % left column below the band
\newbox\wb@Rtop     % right column above the band

\newcount\wb@found  \edef\wb@found@num{\the\allocationnumber}
\newdimen\wb@h      \edef\wb@h@num{\the\allocationnumber}
\newdimen\wb@reserve
\newdimen\wb@botgoal
\newdimen\wb@botnat \edef\wb@botnat@num{\the\allocationnumber}
\newcount\wb@state  % 0 idle / 1 split pending / 2 deferred to next page top
\newcount\wb@defer@request
\newif\ifwb@busy    % a captured band exists until it is actually shipped
\newif\ifwb@reject  % reject a request that would overwrite a pending band

\newskip\wideband@sep
\wideband@sep=14\p@ \@plus 4\p@ \@minus 2\p@
\newcommand\setwidebandsep[1]{\setlength\wideband@sep{#1}}

%% Optional asymmetric rules decorating the captured band.
%% The top rule starts at the left edge; the bottom rule ends at the
%% right edge. The fraction is interpreted as a fraction of \textwidth.
\newdimen\wideband@rulethickness
\wideband@rulethickness=.4\p@
\newskip\wideband@rulesep
\wideband@rulesep=6\p@
\def\wideband@rulefraction{.75}
\newif\ifwideband@rules
\wideband@rulestrue
\newcommand\setwidebandrule[2]{%
  \wideband@rulethickness=#1\relax
  \def\wideband@rulefraction{#2}%
}
\newcommand\setwidebandrulesep[1]{\setlength\wideband@rulesep{#1}}
\newcommand\widebandruleson{\wideband@rulestrue}
\newcommand\widebandrulesoff{\wideband@rulesfalse}

\directlua{
  wideband = require("wideband")
  wideband.setup{ found = \wb@found@num, h = \wb@h@num, botnat = \wb@botnat@num }
}


%% Conservative compatibility checks. These are warnings because the POC can
%% still be useful for visual research, but users must not infer compatibility.
\AtBeginDocument{%
  \@ifpackageloaded{stfloats}{\PackageWarningNoLine{wideband}{stfloats also patches two-column output; compatibility is not guaranteed}}{}%
  \@ifpackageloaded{dblfloatfix}{\PackageWarningNoLine{wideband}{dblfloatfix also patches two-column output; compatibility is not guaranteed}}{}%
  \@ifpackageloaded{cuted}{\PackageWarningNoLine{wideband}{cuted also patches the output routine; do not use strip and wideband on the same page}}{}%
  \@ifpackageloaded{balance}{\PackageWarningNoLine{wideband}{balance may conflict with wideband page surgery}}{}%
  \@ifpackageloaded{flushend}{\PackageWarningNoLine{wideband}{flushend may conflict with wideband page surgery}}{}%
  \@ifpackageloaded{tagpdf}{\PackageWarningNoLine{wideband}{Tagged PDF is unsupported; structure order can be incorrect on band pages}}{}%
}

%% ------------------------------------------------------------------
%% the environment
%% ------------------------------------------------------------------
\newenvironment{wideband}{%
  \if@twocolumn\else
    \PackageError{wideband}{wideband used outside twocolumn mode}%
      {The environment only makes sense in twocolumn documents.}%
  \fi
  \par
  \ifwb@busy
    \global\wb@rejecttrue
    \PackageError{wideband}{A previous wideband is still pending}%
      {This hardened POC supports one pending band at a time.\MessageBreak
       The new band is discarded instead of overwriting the earlier band.\MessageBreak
       Move it later, force a page break, or wait for queue support.}%
    \global\setbox\wb@discard\vbox\bgroup
  \else
    \global\wb@rejectfalse
    \global\setbox\wb@band\vbox\bgroup
  \fi
    \hsize\textwidth \columnwidth\textwidth \linewidth\textwidth
    \@parboxrestore
    \abovedisplayskip\z@skip \belowdisplayskip\z@skip
    \abovedisplayshortskip\z@skip \belowdisplayshortskip\z@skip
    \noindent\ignorespaces
}{%
  \egroup
  \ifwb@reject
    \global\wb@rejectfalse
  \else
    \global\setbox\wb@body=\box\wb@band
    \global\setbox\wb@band=\vbox{%
      \hsize\textwidth \linewidth\textwidth
      \ifwideband@rules
        \hbox to\textwidth{%
          \rule{\wideband@rulefraction\textwidth}{\wideband@rulethickness}\hfil}%
        \vskip\wideband@rulesep
      \fi
      \unvbox\wb@body
      \ifwideband@rules
        \vskip\wideband@rulesep
        \hbox to\textwidth{\hfil
          \rule{\wideband@rulefraction\textwidth}{\wideband@rulethickness}}%
      \fi
    }%
    \global\wb@busytrue
    \wb@place
  \fi
}

\def\wb@place{%
  \ifx\@deferlist\@empty\else
    \PackageWarning{wideband}{Single-column floats are pending; placement on this band page is not guaranteed}%
  \fi
  \ifx\@dbldeferlist\@empty\else
    \PackageWarning{wideband}{Double-column floats are pending; placement on this band page is not guaranteed}%
  \fi
  \global\wb@reserve\dimexpr\ht\wb@band+\dp\wb@band+2\wideband@sep\relax
  \ifdim\wb@reserve>\dimexpr\textheight-2\baselineskip\relax
    \PackageError{wideband}{Wideband is too tall to fit on a page}%
      {The captured band plus its vertical separation is \the\wb@reserve,\MessageBreak
       but this POC requires at least two text baselines on the page.\MessageBreak
       The oversized band is discarded.}%
    \global\wb@busyfalse
  \else
    % if the band cannot fit in what remains of the current column,
    % force a column break so the marker lands at the top of the next one
    \begingroup
      \dimen@\pagegoal
      \ifdim\dimen@=\maxdimen \dimen@\vsize \fi
      \advance\dimen@-\pagetotal
      \ifdim\dimen@<\dimexpr\wb@reserve+\baselineskip\relax
        \vfil\penalty-\@M
      \fi
    \endgroup
    \directlua{wideband.mark(\number\wb@reserve)}%
    \penalty\z@
  \fi
}

%% ------------------------------------------------------------------
%% output routine surgery
%% (based on \@outputdblcol from latex.ltx, 2023 kernel)
%% ------------------------------------------------------------------
\def\@outputdblcol{%
  \if@firstcolumn
    \wb@scan@first
    \global\@firstcolumnfalse
    \global\setbox\@leftcolumn\copy\@outputbox
    \splitmaxdepth\maxdimen
    \vbadness\maxdimen
    \setbox\@outputbox\vbox{\unvbox\@outputbox\unskip}%
    \setbox\@outputbox\vsplit\@outputbox to\maxdimen
    \toks@\expandafter{\topmark}%
    \xdef\@firstcoltopmark{\the\toks@}%
    \toks@\expandafter{\splitfirstmark}%
    \xdef\@firstcolfirstmark{\the\toks@}%
    \ifx\@firstcolfirstmark\@empty
      \global\let\@setmarks\relax
    \else
      \gdef\@setmarks{%
        \let\firstmark\@firstcolfirstmark
        \let\topmark\@firstcoltopmark}%
    \fi
  \else
    \global\@firstcolumntrue
    \wb@scan@second
    \ifcase\wb@state
      % --- state 0: stock kernel assembly --------------------------
      \setbox\@outputbox\vbox{%
        \hb@xt@\textwidth{%
          \hb@xt@\columnwidth{\box\@leftcolumn \hss}%
          \hfil
          {\normalcolor\vrule \@width\columnseprule}%
          \hfil
          \hb@xt@\columnwidth{\box\@outputbox \hss}}}%
    \or
      \wb@assemble@split
    \or
      \wb@assemble@deferred
    \fi
    \@combinedblfloats
    \@setmarks
    \@outputpage
    \wb@after@page
    \begingroup
      \@dblfloatplacement
      \@startdblcolumn
      \@whilesw\if@fcolmade \fi{\@outputpage
      \@startdblcolumn}%
    \endgroup
  \fi}%

%% scan column 1 for the marker; if present, remember its position and
%% shorten the room available to column 2 by the reserved amount.
%% (\@startcolumn copies \@colht into \@colroom and \vsize after every
%% output cycle, so \@colht is the knob that actually controls the
%% height of the next column.)
\def\wb@scan@first{%
  \ifnum\wb@state=\z@
    \directlua{wideband.find(\number\@outputbox)}%
    \ifnum\wb@found>\@ne
      \PackageWarning{wideband}{More than one band on this page;
        only the first is honoured (POC limitation)}%
    \fi
    \ifnum\wb@found>\z@
      \global\wb@state\@ne
      \global\advance\@colht-\wb@reserve
      \PackageInfo{wideband}{band anchored in column 1 at \the\wb@h}%
    \fi
  \fi}

%% if the marker only shows up while assembling column 2, the band
%% cannot be anchored on this page any more (column 1 has already been
%% built at full height).  Fallback: strip the reservation and move the
%% band to the top of the next page.
\def\wb@scan@second{%
  \ifnum\wb@state=\z@
    \directlua{wideband.find(\number\@outputbox)}%
    \ifnum\wb@found>\z@
      \directlua{wideband.strip(\number\@outputbox)}%
      \global\wb@defer@request\@ne
      \PackageWarning{wideband}{Wideband request encountered in column 2; the saved left column is already finalized. The band is being deferred intact to the top of the next page. The current page may end with unused vertical space; no post-band text is moved ahead of the band}%
    \fi
  \fi}

%% state 1: cut both columns at \wb@h and slot the band in between
\def\wb@assemble@split{%
  \global\wb@state\z@
  \global\advance\@colht\wb@reserve    % restore full page height
  \global\wb@botgoal\dimexpr\@colht-\wb@h-\wb@reserve\relax
  % Left column: cut at the marker. Lua returns the lower part at its
  % natural height so we can reject an overfull page instead of hiding
  % excess material below the PDF page boundary.
  \directlua{wideband.split(\number\@leftcolumn,
     \number\wb@Ltop, \number\wb@Lbot,
     \number\wb@h)}%
  \ifdim\wb@botnat>\dimexpr\wb@botgoal+1sp\relax
    \PackageWarning{wideband}{Post-band material does not fit safely;
      deferring the band to the next page}%
    \global\wb@defer@request\@ne
    % Reconstruct a conservative ordinary page. Column 2 was built at
    % reduced height, so it may finish early, but no material is clipped.
    \global\setbox\@leftcolumn\vbox to\@colht{%
      \unvbox\wb@Ltop\unvbox\wb@Lbot\vss}%
    \global\setbox\@outputbox\vbox to\@colht{%
      \unvbox\@outputbox\vss}%
    \setbox\@outputbox\vbox{%
      \hb@xt@\textwidth{%
        \hb@xt@\columnwidth{\box\@leftcolumn\hss}%
        \hfil{\normalcolor\vrule\@width\columnseprule}\hfil
        \hb@xt@\columnwidth{\box\@outputbox\hss}}}%
  \else
    \global\wb@busyfalse
    \begingroup
      \vbadness\maxdimen \vfuzz\maxdimen
      \global\setbox\wb@Lbot\vbox to\wb@botgoal{%
        \unvbox\wb@Lbot\vss}%
      \splittopskip\topskip \splitmaxdepth\@maxdepth
      \global\setbox\wb@Rtop\vsplit\@outputbox to\wb@h
      \global\setbox\@outputbox\vbox to\wb@botgoal{%
        \unvbox\@outputbox\vss}%
    \endgroup
    \global\setbox\@outputbox\vbox to\@colht{%
      \hb@xt@\textwidth{%
        \hb@xt@\columnwidth{\box\wb@Ltop\hss}\hfil
        \hb@xt@\columnwidth{\box\wb@Rtop\hss}}%
      \vskip\wideband@sep
      \hb@xt@\textwidth{\box\wb@band\hss}%
      \vskip\wideband@sep
      \hb@xt@\textwidth{%
        \hb@xt@\columnwidth{\wb@vtop{\wb@Lbot}\hss}\hfil
        \hb@xt@\columnwidth{\wb@vtop{\@outputbox}\hss}}%
      \kern\z@\vss}%
  \fi}

%% state 2: band across the top of this page, columns below
\def\wb@assemble@deferred{%
  \global\wb@state\z@
  \global\wb@busyfalse
  \dimen@\@colht % available column height below the deferred band
  \begingroup
    \vbadness\maxdimen \vfuzz\maxdimen
    \global\setbox\@leftcolumn\vbox to\dimen@{%
      \unvbox\@leftcolumn\vss}%
    \global\setbox\@outputbox\vbox to\dimen@{%
      \unvbox\@outputbox\vss}%
  \endgroup
  \global\advance\@colht\wb@reserve
  \global\setbox\@outputbox\vbox to\@colht{%
    \hb@xt@\textwidth{\box\wb@band\hss}%
    \vskip\wideband@sep
    \hb@xt@\textwidth{%
      \hb@xt@\columnwidth{\box\@leftcolumn\hss}\hfil
      \hb@xt@\columnwidth{\box\@outputbox\hss}}%
    \kern\z@\vss}}

%% top-aligned rebox: height comes from a leading kern, so tops of the
%% two half-columns line up on the row's baseline
\def\wb@vtop#1{\vtop{\kern\z@\unvbox#1}}

%% a deferral scheduled during this page shortens the next page's
%% columns (\@outputpage has just reset \@colht to \textheight)
\def\wb@after@page{%
  \ifnum\wb@defer@request>\z@
    \global\wb@defer@request\z@
    \global\wb@state\tw@
    \global\advance\@colht-\wb@reserve
  \fi}

\endinput
